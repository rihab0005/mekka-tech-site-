# ============================================================
# MEKKA TECH CHATBOT — Variables d'environnement
#
# À renseigner dans Netlify → Site settings → Environment variables
# (PAS dans un fichier .env commité — ces valeurs sont secrètes)
# ============================================================

# Clé API Gemini (Google AI Studio → Get API Key). Gratuite, sans carte bancaire.
GEMINI_API_KEY=AIzaSyxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Modèle Gemini à utiliser (voir ai.google.dev pour la liste à jour)
GEMINI_MODEL=gemini-2.5-flash

# Domaine autorisé à appeler la fonction (protection CORS)
ALLOWED_ORIGIN=https://mekkatech.ma
